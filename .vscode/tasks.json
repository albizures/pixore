{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-project",
      "type": "shell",
      "command": "odin build .. -debug -out:pixore_bin",
      "options": {
        "cwd": "${workspaceFolder}/.build",
      },
      "dependsOn": [
        "mkdir-build-dir"
      ],
      "group": "build",
      "problemMatcher": [],
    },
    {
      "type": "shell",
      "label": "mkdir-build-dir",
      "command": "mkdir -p .build",
      "group": "build",
    },
  ],
}